{
  "name": "goldpan",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.1.2",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter='!goldpan' build",
    "test": "pnpm -r --filter='!goldpan' --filter='!@goldpan/web' build && pnpm -r --filter='!goldpan' test && pnpm check:i18n && pnpm test:scripts",
    "lint": "node scripts/check-channel-adapter-send.mjs && node scripts/sync-managed-env-keys.mjs && node scripts/sync-llm-steps.mjs && node scripts/check-wizard-keys.mjs && biome check .",
    "lint:fix": "biome check --write .",
    "check:i18n": "tsx scripts/check-i18n-parity.ts",
    "test:scripts": "node --test scripts/web-plugins.test.mjs scripts/create-plugin.test.mjs",
    "create-plugin": "node scripts/create-plugin.mjs",
    "start": "concurrently --kill-others --kill-others-on-fail --success first -n server,web -c blue,green \"pnpm server:start\" \"pnpm web:start\"",
    "dev:prebuild:core": "pnpm --filter @goldpan/core build",
    "dev:prebuild:rest": "pnpm -r --no-bail --filter='./packages/*' --filter='!@goldpan/core' --filter='./plugins/*' run build",
    "dev:prebuild": "pnpm dev:prebuild:core && (pnpm dev:prebuild:rest; exit 0)",
    "dev": "pnpm dev:prebuild && node scripts/supervised-start.mjs dev:run",
    "dev:run": "concurrently --kill-others --kill-others-on-fail --success first -n server,web -c blue,green \"pnpm server:dev\" \"pnpm web:dev\"",
    "web:list": "node scripts/web-plugins.mjs list",
    "web:start": "node scripts/web-plugins.mjs run start",
    "web:dev": "node scripts/web-plugins.mjs run dev",
    "server:dev": "pnpm --filter @goldpan/server dev",
    "server:build": "pnpm --filter @goldpan/server build",
    "server:start": "pnpm --filter @goldpan/server start",
    "start:supervised": "node scripts/supervised-start.mjs",
    "onboard": "GOLDPAN_FORCE_WIZARD=true pnpm dev",
    "onboard:cli": "node scripts/onboard-cli.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@formatjs/icu-messageformat-parser": "^3.5.3",
    "concurrently": "^9.2.1",
    "handlebars": "^4.7.8",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp",
      "sqlite-vec"
    ]
  },
  "dependencies": {
    "@goldpan/core": "workspace:*",
    "prompts": "^2.4.2"
  }
}
