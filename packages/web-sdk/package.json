{
  "name": "@goldpan/web-sdk",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "default": "./src/react/index.ts"
    },
    "./health-hash": {
      "types": "./dist/health-hash.d.ts",
      "import": "./dist/health-hash.mjs",
      "default": "./src/health-hash.ts"
    }
  },
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.0"
  }
}
