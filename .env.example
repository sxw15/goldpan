# ============================================================
# Goldpan V1 Configuration
# ============================================================

# --- Onboarding wizard (first-time setup) ---
# Guided UI: open /onboarding in the web app after `pnpm dev`. Headless: `pnpm onboard:cli`
# (use when GOLDPAN_WEB_ENABLED=false). From the repo root, `pnpm onboard` sets FORCE_WIZARD and starts dev.
# GOLDPAN_FORCE_WIZARD=true    # Force wizard on next restart (one-shot; supervised-start.mjs strips it from child env)
# GOLDPAN_WEB_ENABLED=true     # docker-entrypoint / wizard page 1. false = server-only / IM-only; use onboard:cli for .env

# --- Provider API Keys (set only for providers you reference in GOLDPAN_LLM_*) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-v1-...   # OpenAI-compatible aggregator (hundreds of models via one key)
# --- Search tool keys (tracking plugin; plugins try highest-priority configured provider first) ---
# 每个引擎都需要先设 ENABLED=true 再生效（与 settings UI 的 toggle 对应）。仅填 key 不开 toggle
# 视为"已知凭证但不参与调度"，便于在不同环境间切换而无需删 key。
# TAVILY_API_KEY=
# GOLDPAN_TAVILY_SEARCH_ENABLED=false
# SERPER_API_KEY=
# GOLDPAN_SERPER_SEARCH_ENABLED=false
# EXA_API_KEY=
# GOLDPAN_EXA_SEARCH_ENABLED=false
# BRAVE_SEARCH_API_KEY=
# GOLDPAN_BRAVE_SEARCH_ENABLED=false
# SEARXNG_BASE_URL=
# GOLDPAN_SEARXNG_SEARCH_ENABLED=false
# Google 走 Playwright 抓 SERP，需要主动启用：CAPTCHA 风险 + 资源占用 + 反爬限速
# GOLDPAN_GOOGLE_SEARCH_ENABLED=false
# 每小时最大搜索次数（默认 20）。越高越容易触发 CAPTCHA。
# GOLDPAN_GOOGLE_SEARCH_HOURLY_LIMIT=20
# 两次搜索之间的最小等待 ms（默认 2000）。
# GOLDPAN_GOOGLE_SEARCH_DELAY_MIN_MS=2000
# 两次搜索之间的最大等待 ms（默认 5000）。
# GOLDPAN_GOOGLE_SEARCH_DELAY_MAX_MS=5000

# --- Provider base URL overrides (optional: proxy, self-hosted gateway, local Ollama) ---
# Each provider's SDK uses its built-in default when unset; only set these to route through
# a proxy (Helicone / Cloudflare AI Gateway / corporate gateway) or self-hosted endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Set to true to surface ollama in the Pipeline provider dropdown. Default false
# keeps users without a local Ollama daemon from seeing a failing option.
# GOLDPAN_OLLAMA_ENABLED=false
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Per-provider model lists (for Pipeline 模型分配 dropdown) ---
# 每个 provider 在 Settings → Provider 页可编辑的 model 清单 — Pipeline 页下拉读
# 同一份数据。逗号分隔；空 / 不设 → Pipeline 下拉空，用户改用「自定义」直接输入。
# 适用 builtin (anthropic / openai / google / deepseek / openrouter / ollama) 和
# 下面声明的 custom provider — 命名约定一致。
#
# GOLDPAN_LLM_PROVIDER_ANTHROPIC_MODELS=claude-sonnet-4-5-20250929,claude-haiku-4-5-20251001
# GOLDPAN_LLM_PROVIDER_OPENAI_MODELS=gpt-4o,gpt-4o-mini
# GOLDPAN_LLM_PROVIDER_GOOGLE_MODELS=gemini-2.0-flash,gemini-1.5-pro
# GOLDPAN_LLM_PROVIDER_DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner
# GOLDPAN_LLM_PROVIDER_OPENROUTER_MODELS=anthropic/claude-sonnet-4,openai/gpt-4o-mini
# GOLDPAN_LLM_PROVIDER_OLLAMA_MODELS=llama3.2:8b,qwen2.5:7b

# --- Custom LLM providers (OpenAI-compatible) ---
# 自部署用户在不修改 goldpan 代码的前提下接入任意 OpenAI-compatible 端点
# (Together / Groq / Cerebras / Fireworks / SiliconFlow /
#  Moonshot / 智谱 / Qwen / vLLM / LM Studio / 自建 LiteLLM proxy 等)。
# OpenRouter 已是内置 provider — 直接用 openrouter:<model> + OPENROUTER_API_KEY。
#
# 每个 custom provider 一组三行 (id 段须大写、字母 / 下划线 / 数字组成);
# 第四行 _MODELS 与上面 builtin 同一命名约定:
#
# GOLDPAN_LLM_PROVIDER_TOGETHER_BASE_URL=https://api.together.xyz/v1
# GOLDPAN_LLM_PROVIDER_TOGETHER_API_KEY_ENV=TOGETHER_API_KEY
# GOLDPAN_LLM_PROVIDER_TOGETHER_MODELS=meta-llama/Llama-3-70B-Instruct-Turbo,mistralai/Mixtral-8x7B-Instruct-v0.1
# TOGETHER_API_KEY=tgp_xxxxxxxxxxxx
#
# 然后在 step 配置里引用 (provider id 为 lowercased <ID> 段):
# GOLDPAN_LLM_CLASSIFIER=together:meta-llama/Llama-3-70B-Instruct-Turbo
#
# 注意:
#   - id 不能与内置冲突 (openai / anthropic / google / deepseek / ollama / openrouter)
#   - apiKeyEnv 引用的 env var 必须在同一份 .env 里设置, 否则启动失败
#   - per-step provider options (GOLDPAN_LLM_*_OPTIONS) v1 仅对内置 4 家
#     (anthropic / openai / google / deepseek) 生效, custom provider 即使
#     设置了也会被忽略

# --- Pipeline step models (format: providerId:modelId; each step may use a different model) ---
# After collection: choose category path and keywords for the content.
GOLDPAN_LLM_CLASSIFIER=openai:gpt-4o-mini
# Extract structured knowledge points from the text.
GOLDPAN_LLM_EXTRACTOR=anthropic:claude-sonnet-4-20250514
# Link new points to existing entities in the knowledge base.
GOLDPAN_LLM_MATCHER=anthropic:claude-sonnet-4-20250514
# Compare new vs existing facts; output mode uses OUTPUT_*_THRESHOLD below.
GOLDPAN_LLM_COMPARATOR=anthropic:claude-sonnet-4-20250514
# Optional second-pass cross-check (only runs when VERIFIER_ENABLED is true).
GOLDPAN_LLM_VERIFIER=openai:gpt-4o-mini
# true = run verifying step; false = skip (verifier model ignored).
GOLDPAN_LLM_VERIFIER_ENABLED=false
# Classify user input intent (submit / query / record). Also used for query understanding.
GOLDPAN_LLM_INTENT=openai:gpt-4o-mini
# Synthesize answers from knowledge base search results.
GOLDPAN_LLM_QUERY=anthropic:claude-sonnet-4-20250514
# Entity relation extraction step (only when RELATION_ENABLED is true).
# GOLDPAN_RELATION_ENABLED=false
# GOLDPAN_LLM_RELATOR=openai:gpt-4o-mini

# --- Per-step provider options (reasoning / thinking, optional) ---
# Forwarded verbatim to Vercel AI SDK as `providerOptions[<provider>]`. The
# entry whose provider matches the step's model is applied at request time;
# mismatched entries are kept (so you can preset multi-provider configs) but
# warned at startup.
#
# Most users should set these from the settings UI: open Settings → LLM →
# expand the per-step "高级 / Advanced" disclosure → pick a tier (Off / Low /
# Medium / High / Max). The UI writes the same env keys as below via runtime
# override, so you only need to hand-edit this file for shapes outside the
# 5-tier ladder (e.g. custom budgetTokens, reasoningSummary).
#
# Format: GOLDPAN_LLM_<STEP>_<PROVIDER>_OPTIONS=<JSON object>
#   <STEP>:     CLASSIFIER, EXTRACTOR, MATCHER, COMPARATOR, VERIFIER, RELATOR,
#               TRANSLATOR, INTENT, QUERY, DIGEST_SUMMARY, DIGEST_ACTION
#   <PROVIDER>: ANTHROPIC, OPENAI, GOOGLE, DEEPSEEK
#
# Per-provider field reference (these change with model versions — check the
# AI SDK provider docs for the latest):
#   - https://ai-sdk.dev/providers/ai-sdk-providers/anthropic
#   - https://ai-sdk.dev/providers/ai-sdk-providers/openai
#   - https://ai-sdk.dev/providers/ai-sdk-providers/google-generative-ai
#   - https://ai-sdk.dev/providers/ai-sdk-providers/deepseek
#
# Examples (hand-rolled; UI-managed configs use the tier ladder instead):
# GOLDPAN_LLM_EXTRACTOR_ANTHROPIC_OPTIONS='{"thinking":{"type":"adaptive"}}'
# GOLDPAN_LLM_QUERY_OPENAI_OPTIONS='{"reasoningEffort":"high","reasoningSummary":"auto"}'
# GOLDPAN_LLM_CLASSIFIER_GOOGLE_OPTIONS='{"thinkingConfig":{"thinkingLevel":"low"}}'
# GOLDPAN_LLM_EXTRACTOR_DEEPSEEK_OPTIONS='{"thinking":{"type":"enabled"}}'

# --- Pipeline parameters ---
# Seconds between background worker polls for pending tasks.
GOLDPAN_WORKER_INTERVAL=5
# Seconds before URL fetch / collector plugin HTTP request times out.
GOLDPAN_COLLECT_TIMEOUT=30
# Browser collector: auto (try system Chrome, then Playwright Chromium), bundled, or system-chrome only.
# GOLDPAN_BROWSER_STRATEGY=auto
# Optional: absolute path to a Chrome/Chromium binary (overrides strategy when set).
# GOLDPAN_BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# --- Collector-media (yt-dlp 视频源：YouTube / Bilibili / Vimeo) ---
# 视频 collector 整体超时（秒），独立于 GOLDPAN_COLLECT_TIMEOUT
GOLDPAN_MEDIA_COLLECT_TIMEOUT=90
# yt-dlp 自动检查更新；关闭后只用本地 PINNED 版本
GOLDPAN_YT_DLP_AUTO_UPDATE=true
# 钉死特定 yt-dlp 版本（覆盖 auto-update）
# GOLDPAN_YT_DLP_VERSION=2026.01.15
# 外部 yt-dlp binary 路径（跳过下载/升级；用系统已安装的 yt-dlp）
# GOLDPAN_YT_DLP_BINARY_PATH=/usr/local/bin/yt-dlp
# yt-dlp binary + version.txt 存放位置（默认 ${dataDir}/yt-dlp）
# GOLDPAN_YT_DLP_DIR=
# GitHub latest 查询缓存（小时）
GOLDPAN_YT_DLP_UPDATE_CHECK_INTERVAL_H=24
# yt-dlp cookies.txt 路径（B 站会员视频等场景）
# GOLDPAN_YT_DLP_COOKIES_PATH=/path/to/cookies.txt
# Seconds before a single LLM call times out. Used as the GLOBAL FALLBACK for
# every step; individual steps can override via GOLDPAN_LLM_<STEP>_TIMEOUT below
# (or via the settings UI · Model Service · Pipeline model assignment row).
GOLDPAN_LLM_TIMEOUT=600
# Per-step LLM timeout overrides (seconds, integer 1..600). Unset = inherit
# GOLDPAN_LLM_TIMEOUT. Same names as the model env vars + `_TIMEOUT` suffix.
# Use these when one step (e.g. extractor with a reasoning model) needs a
# longer wall time than the others, or when a small/fast step (classifier)
# should fail fast.
# GOLDPAN_LLM_CLASSIFIER_TIMEOUT=15
# GOLDPAN_LLM_EXTRACTOR_TIMEOUT=120
# GOLDPAN_LLM_MATCHER_TIMEOUT=60
# GOLDPAN_LLM_COMPARATOR_TIMEOUT=60
# GOLDPAN_LLM_VERIFIER_TIMEOUT=30
# GOLDPAN_LLM_RELATOR_TIMEOUT=45
# GOLDPAN_LLM_INTENT_TIMEOUT=15
# GOLDPAN_LLM_QUERY_TIMEOUT=60
# GOLDPAN_LLM_DIGEST_SUMMARY_TIMEOUT=120
# GOLDPAN_LLM_DIGEST_ACTION_TIMEOUT=30
# Comparing step: if existing fact count <= this, use full_summary output mode.
GOLDPAN_OUTPUT_FULL_THRESHOLD=2
# Comparing step: if count <= this (and > FULL), use summary_plus_increment; else increment_only. Must be >= FULL.
GOLDPAN_OUTPUT_INCREMENT_THRESHOLD=10
# Max characters for user-pasted text input.
GOLDPAN_MAX_TEXT_INPUT_LENGTH=20000
# Intent classifier input: 0 = send full text (up to MAX_TEXT_INPUT_LENGTH); >0 = truncate to N chars.
# GOLDPAN_INTENT_CLASSIFICATION_CHAR_LIMIT=0
# Max characters for collected page/body content after fetching.
GOLDPAN_MAX_CONTENT_LENGTH=30000
# Min characters of collected/pasted content required to run the pipeline. Below
# this, the collecting step fails fast with errorKind `content_length` (not a
# content-policy violation). Must be ≤ GOLDPAN_MAX_CONTENT_LENGTH.
GOLDPAN_MIN_CONTENT_LENGTH=50

# --- Embedding / Vector Search (opt-in) ---
# Master switch: true = load sqlite-vec, enable hybrid FTS+vector search. false = FTS only.
# GOLDPAN_EMBEDDING_ENABLED=false
# Embedding model (format: providerId:modelId). Only used when EMBEDDING_ENABLED is true.
# GOLDPAN_EMBEDDING_MODEL=openai:text-embedding-3-small
# Vector dimensions. 0 = auto-detect via a probe call on first startup; >0 = fixed.
# GOLDPAN_EMBEDDING_DIMENSIONS=0
# Records per batch during embedding backfill on startup.
# GOLDPAN_EMBEDDING_BATCH_SIZE=100

# --- Logging ---
# One of: debug, info, warn, error.
GOLDPAN_LOG_LEVEL=info
# When true, persist full LLM request/response (including user content) in logs. If unset: true in dev, false in prod.
# GOLDPAN_LLM_LOG_PAYLOADS=true

# --- Database ---
# V1 supports sqlite only; postgresql is reserved for a future version.
GOLDPAN_DB_TYPE=sqlite
# SQLite file path (created automatically under this path).
GOLDPAN_DB_SQLITE_PATH=./data/goldpan.db
# Only used when GOLDPAN_DB_TYPE=postgresql (not supported in V1 yet).
# GOLDPAN_DB_URL=postgres://user:pass@host:5432/goldpan

# --- Auth ---
# Required when NODE_ENV=production. Omit in development for no password gate.
# GOLDPAN_AUTH_PASSWORD=your-secret-password

# --- Language ---
# UI and prompts: en | zh. Language is persisted once data exists; switching needs a new DB (see README.md).
GOLDPAN_LANGUAGE=en

# --- Translate pipeline output ---
# When true, the pipeline runs an additional translation step that translates
# facts / opinions / entity descriptions / relation descriptions / summaries
# into GOLDPAN_LANGUAGE. Originals stay in the DB; UI shows the translation by
# default and can switch back to the original on each card. Hot-reloadable —
# next pipeline run picks up the change.
# GOLDPAN_TRANSLATE_PIPELINE_OUTPUT=false
# Model used by the translating step. Only consulted when the toggle is on.
# GOLDPAN_LLM_TRANSLATOR=openai:gpt-4o-mini
# Per-step timeout override (seconds). Falls back to GOLDPAN_LLM_TIMEOUT.
# GOLDPAN_LLM_TRANSLATOR_TIMEOUT=30

# --- Timezone ---
# IANA tz string used for digest scheduling + UI display. Onboarding 会自动从浏览器探测后写入。
# 跳过 onboarding 直接 .env 部署时,留空走 server boot fallback:process.env.TZ → Intl 探测 → UTC。
# 接受 'Asia/Shanghai' / 'America/New_York' / 'UTC' / 'Etc/GMT-8' 等。
# GOLDPAN_TIMEZONE=Asia/Shanghai

# --- Server (standalone worker mode) ---
# HTTP port for the standalone server (apps/server). Not used in all-in-one web mode.
# GOLDPAN_SERVER_PORT=3001
# Socket inactivity timeout (ms). 0 = no timeout (default). If set >0, must exceed worst-case LLM wall time for POST /input and /query (multiple chained calls).
# GOLDPAN_SERVER_SOCKET_TIMEOUT_MS=0
# When true, rate limiting uses X-Forwarded-For header instead of socket.remoteAddress. Only enable behind a trusted reverse proxy.
# GOLDPAN_TRUST_PROXY=false

# --- SSRF pre-flight (user-supplied URLs) ---
# When true, submit + collector resolve DNS for every URL the user pastes
# and reject private/reserved IPs (loopback, link-local, cloud metadata
# 169.254.169.254, etc.). Defaults to false because the typical Goldpan
# deployment is single-user / small-team behind a transparent proxy
# (Clash / Surge / V2Ray) whose fake-IP mode maps public domains to
# reserved ranges (198.18.0.0/15, 100.64.0.0/10) — with SSRF on, those
# legitimate URLs get rejected as "URL blocked by security policy".
# Flip to true if you expose the server to untrusted submitters.
# GOLDPAN_SSRF_VALIDATION_ENABLED=false

# --- Startup Orchestration ---
# Web app port (Next.js binds to this via PORT env var). Used by root 'dev'/'start' scripts.
# GOLDPAN_WEB_PORT=3000
# URL the web app uses to reach the server API. Read at request time by Next.js
# middleware (NextResponse.rewrite) so a single Docker image can be deployed in
# all-in-one (defaults to localhost:3001) and split mode (set to the worker host).
# GOLDPAN_SERVER_URL=http://localhost:3001
# Workspace package name of the web app (for root scripts). Override to use a custom frontend.
# GOLDPAN_WEB_PACKAGE=@goldpan/web
# Seconds the Docker entrypoint waits for `bootstrap()` (migrations + optional
# embedding backfill + plugin init) before giving up and killing the server.
# Increase if you have a large existing DB and embedding backfill is slow.
# GOLDPAN_SERVER_READY_TIMEOUT_S=120

# ─── IM Subsystem ─────────────────────────────────────────────────────
# Conversation history depth (number of messages loaded into IntentExecutionContext.conversation)
GOLDPAN_IM_CONVERSATION_WINDOW_SIZE=8
# Retention (days) for ARCHIVED conversations. Phase 1 ships `purgeArchived(olderThan)` as a
# repository API only — there is NO automatic cron yet. This value is parsed and surfaced on
# `handle.config.im.conversationTtlDays` so future ops tooling (e.g. `pnpm goldpan im purge`)
# can read it without another env-var roundtrip. Active conversations are NEVER affected.
GOLDPAN_IM_CONVERSATION_TTL_DAYS=30
# Inbound dedupe table (im_messages_seen) retention. The table only protects against
# crash/poll-cursor double-deliveries — its useful window is minutes. The runtime sweeps
# rows older than this on a timer (see GOLDPAN_IM_DEDUPE_PURGE_INTERVAL_MINUTES below).
# Set to 0 to disable the periodic purge entirely (rows then accumulate forever).
GOLDPAN_IM_DEDUPE_TTL_HOURS=72
# How often the runtime sweeps im_messages_seen for expired rows. Set to 0 to disable.
GOLDPAN_IM_DEDUPE_PURGE_INTERVAL_MINUTES=60

# ─── Telegram (long-polling) ──────────────────────────────────────────
# Bot token from @BotFather. Use `env://VAR_NAME` to defer to another env var.
# When empty, the Telegram channel is disabled.
GOLDPAN_IM_TELEGRAM_BOT_TOKEN=
# Comma-separated list of chat IDs allowed to talk to the bot (mandatory when bot token set).
GOLDPAN_IM_TELEGRAM_ALLOWED_CHAT_IDS=
# Master switch for the Telegram channel. 'true' = enabled (default), 'false' = disabled.
# When 'false', the channel will not start even if a bot token is present.
# Combined with the token presence check: real `enabled = (token set) AND (flag === 'true')`.
# Requires a server restart to apply.
# GOLDPAN_IM_TELEGRAM_ENABLED=true

# Future modes (Phase 2):
# GOLDPAN_IM_TELEGRAM_MODE=polling          # polling | webhook
# GOLDPAN_IM_TELEGRAM_WEBHOOK_URL=          # required when mode=webhook
# GOLDPAN_IM_TELEGRAM_WEBHOOK_SECRET=       # X-Telegram-Bot-Api-Secret-Token validation

# ─── Feishu (WebSocket) ──────────────────────────────────────────────
# Lark application id (e.g. `cli_xxxxx`). When empty, the Feishu channel is disabled.
GOLDPAN_IM_FEISHU_APP_ID=
# Lark application secret. Both APP_ID and APP_SECRET must be set to enable the channel;
# setting only one emits a startup warning and disables Feishu.
GOLDPAN_IM_FEISHU_APP_SECRET=
# Optional: event-payload decrypt key (matches the Lark admin panel "Encrypt Key" field).
# Leave UNSET (not empty string) when encryption is not configured. Empty-string fails
# at startup to catch misconfiguration.
# GOLDPAN_IM_FEISHU_ENCRYPT_KEY=
# `feishu.cn` (default) for Feishu / mainland-China apps; `larksuite.com` for Lark
# International. Any other value fails fast at startup.
GOLDPAN_IM_FEISHU_DOMAIN=feishu.cn
# Master switch for the Feishu channel. 'true' = enabled (default), 'false' = disabled.
# When 'false', the channel will not start even if APP_ID/APP_SECRET are present.
# Combined with the credential presence check: real `enabled = (APP_ID + APP_SECRET set) AND (flag === 'true')`.
# Requires a server restart to apply.
# GOLDPAN_IM_FEISHU_ENABLED=true

# ─── GitHub collector + intent (Phase 1) ─────────────────────────────
# Personal access token for github.com API. Unauthenticated requests are capped at
# 60/h which is too low to be useful — set a token (no scopes needed for public repos).
GOLDPAN_GITHUB_TOKEN=
# Override for self-hosted GitHub Enterprise. Default: public github.com API.
GOLDPAN_GITHUB_API_BASE=https://api.github.com
# Cooldown enforced by GithubService.refreshRepo so users can't spam refresh
# on the same repo. Unit: seconds.
GOLDPAN_GITHUB_REFRESH_MIN_INTERVAL_SEC=60
# How many recent commits the collector fetches per refresh (upper bound).
GOLDPAN_GITHUB_RECENT_COMMITS_LIMIT=20
# How many recent releases the collector fetches per refresh (upper bound).
GOLDPAN_GITHUB_RECENT_RELEASES_LIMIT=10
# Per-request HTTP timeout for GitHub API calls.
GOLDPAN_GITHUB_HTTP_TIMEOUT_SEC=15
# Per-section truncation cap (applied to README and CHANGELOG individually) in bytes.
# Unset → falls back to GOLDPAN_MAX_CONTENT_LENGTH. Set this only to raise the cap
# above core's limit; ensure GOLDPAN_MAX_CONTENT_LENGTH is raised accordingly or
# the pipeline will reject oversize stitched content with content_too_long.
# GOLDPAN_GITHUB_MAX_CONTENT_LENGTH=
# Whether to strip badges / HTML comments from README before stitching. "true" or "false".
GOLDPAN_GITHUB_README_CLEAN=true

# ─── Buffer release (P3 — wait-decision 释放兜底 cron) ────────────────
# `decision='wait'` 写入 buffered_wait 后，由 5 路释放：A 同 session 新消息 / B
# 用户点 release|cancel / C handleInput 入口扫 expired / D GET /conversations
# reconcile / E 后台 cron。E 通过 setTimeout 自循环，默认 5 min。详见
# .agent/input-query.md `Buffer 机制（P3 起）`。
# GOLDPAN_DISABLE_BUFFER_WATCHER=false   # true 关闭 Path E（测试 / 调试 / 多实例只想留一个 watcher）
# GOLDPAN_BUFFER_WATCHER_INTERVAL_MS=300000   # Path E tick 间隔；默认 5 min
# GOLDPAN_BUFFER_WATCHER_GRACE_MS=30000   # client 倒计时 vs server 时钟漂移容忍；默认 30s

# ─── Deferred entity resolution (P4 — clarify-timeout 兜底 cron) ─────
# create_tracking + source 还在 pipeline / create_note linkedSource 还在
# pipeline → 落 pending 状态，source 终态时由 sourceRepo.onTerminated 触发
# deferredResolver。awaiting_clarify 状态（多 entity 候选）需用户在 24h 内
# 选择，否则 clarify-timeout-watcher 自动标 failed_no_entity + push reminder。
# 详见 .agent/input-query.md `Deferred Entity Resolution`。
# GOLDPAN_DISABLE_CLARIFY_TIMEOUT_WATCHER=false   # true 关闭 watcher（测试 / 调试）
# GOLDPAN_CLARIFY_TIMEOUT_WATCHER_INTERVAL_MS=21600000   # tick 间隔；默认 6h
# GOLDPAN_CLARIFY_TIMEOUT_HOURS=24   # awaiting_clarify 多久后自动 fail；默认 24h

# ─── Tracking plugin (scheduled keyword search + auto-submit) ─────────
# Master switch: when true, bootstrap starts the tracking scheduler.
# GOLDPAN_TRACKING_SCHEDULER_ENABLED=false
# Seconds between scheduler polls (plugin default 60 if unset).
# GOLDPAN_TRACKING_POLL_INTERVAL=60
# Max search executions per day across all rules (plugin default 100 if unset).
# GOLDPAN_TRACKING_DAILY_SEARCH_LIMIT=100
# Optional tuning (see plugins/tracking): minimum minutes between runs per rule; max results per search call.
# GOLDPAN_TRACKING_MIN_RULE_INTERVAL=60
# GOLDPAN_TRACKING_MAX_RESULTS_PER_SEARCH=10

# ─── Digest plugin ────────────────────────────────────────────────────
# Master switch. true = load digest plugin (registers /digest API routes,
# starts the daily scheduler, enables IM push subscriptions). Default false;
# the /digest page in the web app shows a "plugin disabled" notice with this
# enable hint until you flip it on.
# GOLDPAN_DIGEST_ENABLED=false
# Daily generation time, HH:MM in local timezone. Only used when enabled.
# GOLDPAN_DIGEST_DAILY_TIME=06:00
# Max items rendered per digest module (tracking / entities / thoughts / captures).
# GOLDPAN_DIGEST_MAX_ITEMS_PER_MODULE=10
# LLM models for digest body summary and action parsing (used when digest plugin is enabled).
# GOLDPAN_LLM_DIGEST_SUMMARY=anthropic:claude-sonnet-4-20250514
# GOLDPAN_LLM_DIGEST_ACTION=openai:gpt-4o-mini
# --- Signed share links (optional, used by IM push footer) ---
# Random secret (≥32 chars; recommend 64 hex chars from `openssl rand -hex 32`).
# Required only if you want IM push to include shareable digest URLs.
# GOLDPAN_DIGEST_LINK_SIGNING_KEY=
# How long share links remain valid (default 14 days).
GOLDPAN_DIGEST_LINK_TTL_DAYS=14
# Public origin without trailing slash (e.g. https://digest.example.com).
# GOLDPAN_DIGEST_PUBLIC_BASE_URL=
